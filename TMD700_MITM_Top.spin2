'' =================================================================================================
''
''   File....... TMD700_MITM_Top.spin2
''   Purpose.... Kenwood TM-D700 head<->body UART MITM bridge  (Parallax Propeller 2)
''   Author..... Terry (KE4PJW) / ke4pjw  --  built with Claude Code
''   Target..... P2, spinc.exe  (see SPINC_BUILD.md)
''
''   STAGE 2 of the incremental build: DECODED FRAME MONITOR.
''   The PASM2 forwarder cog still repeats every byte transparently between head
''   and body (Stage 1), and now ALSO drops each received byte -- tagged with its
''   origin -- into a hub ring buffer.  Cog0 drains that ring, assembles frames
''   (tag .. 0x0D), and prints them decoded over the DEBUG terminal as:
''
''       HEAD: [0x83]
''       HEAD: [0x8F]01
''       BODY: N0144.390
''       BODY: J1
''
''   Printable ASCII (0x20-0x7E) is shown as-is; other bytes as [0xNN].  Bare
''   0xFF keepalives are suppressed by default; bare 0x0D power-on sync is shown.
''
''   Timing decoupling is the point: the forwarder never blocks on DEBUG.  It
''   only writes a word to hub per byte (near free); the slow 2 Mbaud formatting
''   and printing all happen in cog0, which can lag briefly during a burst and
''   catch up in the next idle gap without ever disturbing the radio.
''
''   Next stage (needs the PC UART on P4/P5 wired, plus P6 LED / P7 PTT):
''     Stage 3 - PC protocol: injection, MODE PASS/INJECT/HEADLESS/BODYLESS, QUIET
''   See tmd700_p2_mitm_architecture.md for the full spec.
''
'' =================================================================================================
''
''   WIRING  (Terry's inline tap -- pairs grouped by data-flow direction):
''
''            P0  HEAD_OUT   TX -> control head RX   \_ BODY->HEAD repeater (P1 in, P0 out)
''            P1  BODY_IN    RX <- RF deck  TX        /
''            P2  BODY_OUT   TX -> RF deck  RX        \_ HEAD->BODY repeater (P3 in, P2 out)
''            P3  HEAD_IN    RX <- control head TX    /
''
''   Radio link: 57600 baud, 8N1, idle-high, CMOS 3.3V.  Frame = tag + payload + $0D.
''
'' =================================================================================================


con { clock }

  '' 20 MHz crystal (P2 Eval / Edge) -> 200 MHz via PLL.  Confirmed correct for
  '' this board in Stage 1 (DEBUG terminal is clean).
  _clkfreq = 200_000_000


con { radio link }

  BAUD_RADIO   = 57_600

  PIN_HEAD_OUT = 0                                              ' TX -> head   (BODY->HEAD data)
  PIN_BODY_IN  = 1                                              ' RX <- body   (BODY->HEAD data)
  PIN_BODY_OUT = 2                                              ' TX -> body   (HEAD->BODY data)
  PIN_HEAD_IN  = 3                                              ' RX <- head   (HEAD->BODY data)


con { monitor }

  RING_N    = 1024                                             ' ring entries (must be power of 2)
  RING_MASK = RING_N - 1
  MAXFRAME  = 64                                               ' max bytes buffered per frame
  LINE_MAX  = 512                                              ' formatted output line buffer

  QUIET_IDLE = TRUE                                            ' suppress idle keepalives (bare 0xFF and bare 0x0D)
  GAP_MS     = 500                                             ' idle gap that inserts a burst divider

  DIR_HEAD  = 0                                                ' byte originated at control head
  DIR_BODY  = 1                                                ' byte originated at RF deck

  '' Ring-buffer entry, filled by the forwarder cog at RECEIVE time.  Packed
  '' (no padding) so the PASM producer and Spin consumer agree on the layout:
  ''   offset 0: dir    1: token    2-3: attr    4-7: ms
  STRUCT rxentry(BYTE dir, BYTE token, WORD attr, LONG ms)
  ENTRY_BYTES = 8                                              ' = sizeof(rxentry); PASM producer stride

  '' attribute flags (set by the forwarder from the raw byte value)
  ATTR_KEEPALIVE = %01                                         ' token is a bare 0xFF idle keepalive
  ATTR_CR        = %10                                         ' token is 0x0D (frame terminator / power-on sync)


obj

  strs : "jm_strings"                                          ' string build + number formatting


var

  '' shared with the forwarder cog via PTRA (must stay first / contiguous)
  long  mbox[4]                                                ' [0]=bitmode [1]=wr_idx [2]=@ring [3]=ms_pub
  rxentry ring[RING_N]                                         ' forwarder -> logger, defined-layout entries

  '' logger (cog0) state
  long  rd_idx                                                 ' consumer index
  word  flen[2]                                                ' in-progress frame length per direction
  long  fstart[2]                                              ' receive-ms of the frame's first byte, per direction
  byte  fbuf[2 * MAXFRAME]                                     ' per-direction frame assembly buffers
  byte  linebuf[LINE_MAX]                                      ' formatted output line
  long  n_frames                                               ' frames decoded
  long  n_idle                                                 ' idle keepalive bytes suppressed
  long  n_over                                                 ' ring-overflow bytes lost

  '' millisecond clock + burst segmentation
  long  ms_now                                                 ' ms since boot (monotonic)
  long  ct_prev                                                ' last getct() sample
  long  tick_frac                                              ' leftover ticks < 1 ms
  long  ticks_ms                                               ' clock ticks per ms
  long  last_emit_ms                                           ' ms of last printed frame


pub main() | wr, laststat_ms, now, rxentry ent

  '' async smart-pin bit timing (same recipe as jm_serial)
  mbox[0] := muldiv64(clkfreq, $1_0000, BAUD_RADIO) & $FFFF_FC00
  mbox[0] |= 7
  mbox[1] := 0                                                 ' wr_idx (entries)
  mbox[2] := @ring                                            ' hand the ring base to the forwarder
  mbox[3] := 0                                                ' ms_pub (we publish current ms here)

  rd_idx  := 0
  flen[0] := 0
  flen[1] := 0

  ticks_ms     := clkfreq / 1000
  ms_now       := 0
  tick_frac    := 0
  ct_prev      := getct()
  last_emit_ms := 0
  laststat_ms  := 0

  coginit(COGEXEC_NEW, @forwarder, @mbox)                      ' launch transparent forwarder

  debug("TM-D700 MITM  Stage 2.5: protocol explorer  (57600 8N1)")
  debug("  idle keepalives suppressed; [ms] timestamps; blank line = idle gap")

  repeat
    '' advance the millisecond clock (loop is tight, so getct() never laps 32-bit)
    now := getct()
    tick_frac += now - ct_prev
    ct_prev := now
    repeat while tick_frac >= ticks_ms
      tick_frac -= ticks_ms
      ms_now++
    mbox[3] := ms_now                                         ' publish ms for the forwarder to stamp entries

    wr := mbox[1]                                             ' latest producer index (entries)
    if rd_idx == wr
      '' idle: periodic liveness so a quiet link doesn't look dead
      if (ms_now - laststat_ms) >= 5000
        laststat_ms := ms_now
        debug("  -- alive: frames=", udec_(n_frames), "  idle=", udec_(n_idle), "  overflow=", udec_(n_over))
    else
      '' overflow guard: if the producer lapped us, skip ahead to the oldest kept entry
      if (wr - rd_idx) > RING_N
        n_over += (wr - rd_idx) - RING_N
        rd_idx := wr - RING_N
      ent := ring[rd_idx & RING_MASK]                         ' struct copy (dir/token/attr/ms)
      rd_idx++
      accumulate(ent)


pri accumulate(rxentry e) | base, len

  '' Feed one received entry into the per-direction frame assembler and emit
  '' completed frames.  The entry carries its own receive-ms and attribute flags.

  base := e.dir * MAXFRAME
  len  := flen[e.dir]

  if len == 0
    '' buffer empty -> either a standalone idle byte or the tag of a new frame
    if (e.attr & (ATTR_KEEPALIVE | ATTR_CR))                  ' idle keepalive (0xFF) / bare sync (0x0D)
      n_idle++
      if QUIET_IDLE == FALSE
        emit1(e.dir, e.token, e.ms)
      return
    fbuf[base] := e.token                                     ' start frame with tag byte
    flen[e.dir]   := 1
    fstart[e.dir] := e.ms                                     ' remember when the frame started
    return

  '' mid-frame
  if e.token == $0D                                           ' terminator -> frame complete
    emit_frame(e.dir, @fbuf[base], len, fstart[e.dir])
    flen[e.dir] := 0
    n_frames++
    return

  fbuf[base + len] := e.token
  len++
  flen[e.dir] := len
  if len >= MAXFRAME                                          ' runaway guard: flush partial
    emit_frame(e.dir, @fbuf[base], len, fstart[e.dir])
    flen[e.dir] := 0
    n_frames++


pri emit1(dr, bt, ts) | tb

  '' Emit a single standalone byte as its own line, stamped with its receive-ms.

  tb := bt
  emit_frame(dr, @tb, 1, ts)


pri emit_frame(dr, pbuf, len, ts) | i, c, gap, BYTE tmp[16]

  '' Format "[ms] HEAD/BODY: ..." into linebuf and print it in one DEBUG call.
  '' 'ts' is the receive-ms of the frame's first byte (from the ring entry).
  '' A gap of GAP_MS since the last frame inserts a blank line to segment bursts.
  '' Uses jm_strings for the string building and number formatting.

  gap := ts - last_emit_ms
  if (last_emit_ms <> 0) and (gap >= GAP_MS)
    debug(" ")
  last_emit_ms := ts

  byte[@linebuf] := 0                                          ' start with an empty z-string

  strs.append_char(@linebuf, "[")
  strs.rjdec(ts, 8, " ", @tmp)                                ' right-justified receive-ms timestamp
  strs.append_str(@linebuf, @tmp)
  strs.append_str(@linebuf, string("] "))

  if dr == DIR_BODY
    strs.append_str(@linebuf, string("BODY: "))
  else
    strs.append_str(@linebuf, string("HEAD: "))

  repeat i from 0 to len - 1
    c := byte[pbuf][i]
    if (c >= $20) and (c <= $7E)                              ' printable -> literal
      strs.append_char(@linebuf, c)
    else                                                      ' otherwise -> [0xNN]
      strs.append_str(@linebuf, string("[0x"))
      strs.fxhex(c, 2, @tmp)
      strs.append_str(@linebuf, @tmp)
      strs.append_char(@linebuf, "]")

  debug(zstr_(@linebuf))


dat { transparent forwarder + ring producer (PASM2) }

              org       0

'' On entry: PTRA = @mbox.  mbox[0]=bitmode, mbox[1]=wr_idx (published here),
'' mbox[2]=@ring, mbox[3]=ms_pub (current ms, published by cog0).  Forwards each
'' received byte immediately (send-first, so the async-TX smart pin never
'' deadlocks -- see Stage 1) and writes a defined rxentry {dir,token,attr,ms}
'' into the ring, timestamped at receive time, for cog0 to decode.

forwarder     mov       adr_wr, ptra
              add       adr_wr, #4                              ' &mbox[1] (wr_idx)
              mov       t0, ptra
              add       t0, #8                                  ' &mbox[2] (@ring)
              rdlong    ringbase, t0
              mov       adr_ms, ptra
              add       adr_ms, #12                             ' &mbox[3] (ms_pub)
              rdlong    bitmode, ptra                           ' mbox[0]
              mov       maskv, ##RING_MASK
              mov       wrx, #0
              wrlong    wrx, adr_wr

              ' ---- receive smart pins (P1 body-in, P3 head-in) ----
              fltl      #PIN_BODY_IN
              wrpin     ##P_ASYNC_RX, #PIN_BODY_IN
              wxpin     bitmode, #PIN_BODY_IN
              drvl      #PIN_BODY_IN

              fltl      #PIN_HEAD_IN
              wrpin     ##P_ASYNC_RX, #PIN_HEAD_IN
              wxpin     bitmode, #PIN_HEAD_IN
              drvl      #PIN_HEAD_IN

              ' ---- transmit smart pins (P0 head-out, P2 body-out) ----
              ' Slew-limit the TX drivers (1.5k instead of the default 30mA fast
              ' driver) so their edges couple far less into the adjacent RX pin
              ' (P0<->P1, P2<->P3).  Still ~30ns edges << 17.4us bit time.
              fltl      #PIN_HEAD_OUT
              wrpin     ##(P_ASYNC_TX | P_OE | P_HIGH_1K5 | P_LOW_1K5), #PIN_HEAD_OUT
              wxpin     bitmode, #PIN_HEAD_OUT
              drvl      #PIN_HEAD_OUT

              fltl      #PIN_BODY_OUT
              wrpin     ##(P_ASYNC_TX | P_OE | P_HIGH_1K5 | P_LOW_1K5), #PIN_BODY_OUT
              wxpin     bitmode, #PIN_BODY_OUT
              drvl      #PIN_BODY_OUT

fwd_loop
              ' ---- BODY -> HEAD ----
              testp     #PIN_BODY_IN            wc              ' C = byte available?
        if_nc jmp       #.chk_head
              rdpin     rxb, #PIN_BODY_IN                       ' read + acknowledge
              shr       rxb, #24                                ' byte lands in bits[31:24]
              wypin     rxb, #PIN_HEAD_OUT                      ' forward now (buffered)
              mov       dirval, #DIR_BODY
              call      #rput

.chk_head
              ' ---- HEAD -> BODY ----
              testp     #PIN_HEAD_IN            wc
        if_nc jmp       #fwd_loop
              rdpin     rxb, #PIN_HEAD_IN
              shr       rxb, #24
              wypin     rxb, #PIN_BODY_OUT                      ' forward now (buffered)
              mov       dirval, #DIR_HEAD
              call      #rput

              jmp       #fwd_loop

'' rput -- write a defined rxentry to the ring and publish the write index.
''   long0 = dir | token<<8 | attr<<16   (bytes: 0=dir 1=token 2..3=attr)
''   long1 = ms  (receive timestamp, bytes 4..7)
'' rxb holds the byte, dirval holds the direction.
rput          mov       hubp, wrx
              and       hubp, maskv
              shl       hubp, #3                                ' entry index -> byte offset (x ENTRY_BYTES=8)
              add       hubp, ringbase

              mov       attrv, #0                               ' derive attribute flags from the raw byte
              cmp       rxb, #$FF               wz
        if_z  or        attrv, #ATTR_KEEPALIVE
              cmp       rxb, #$0D               wz
        if_z  or        attrv, #ATTR_CR

              mov       ent0, rxb                               ' token -> [15:8]
              shl       ent0, #8
              or        ent0, dirval                           ' dir -> [7:0]
              shl       attrv, #16                             ' attr -> [31:16]
              or        ent0, attrv
              wrlong    ent0, hubp                             ' dir/token/attr

              rdlong    msv, adr_ms                            ' current ms (published by cog0)
              add       hubp, #4
              wrlong    msv, hubp                              ' receive timestamp

              add       wrx, #1
              wrlong    wrx, adr_wr
rput_ret      ret

' ---- cog registers ----
bitmode       res       1
adr_wr        res       1                                      ' hub &mbox[1]
ringbase      res       1                                      ' hub @ring
adr_ms        res       1                                      ' hub &mbox[3] (ms_pub)
maskv         res       1                                      ' RING_MASK
wrx           res       1                                      ' producer index (entries)
dirval        res       1                                      ' direction of current byte
attrv         res       1                                      ' attribute flags scratch
ent0          res       1                                      ' packed dir/token/attr long
msv           res       1                                      ' receive-ms scratch
hubp          res       1                                      ' scratch hub address
rxb           res       1                                      ' received byte
t0            res       1                                      ' scratch

              fit
