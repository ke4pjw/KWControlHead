'' =================================================================================================
''
''   File....... TMD700_MITM_Top.spin2
''   Purpose.... Troubleshooting monitor for the TM-D700 head<->body link.  A thin harness
''              over the standalone "tmd700_mitm" object: pulls decoded frames from it and
''              prints them over the DEBUG terminal.  Keep this build for troubleshooting the
''              protocol / the tap while the replacement-head firmware is developed separately.
''   Author.... Terry (KE4PJW) / ke4pjw  --  built with Claude Code
''   Target.... P2, spinc.exe   (build needs -L <spin-tools>/library/spin2  for jm_strings)
''
''   Output:
''       [   59244] BODY: N0144.390
''       [   60342] HEAD: [0x8F]01
''   Printable ASCII (0x20-0x7E) shown as-is, other bytes as [0xNN].  Idle keepalive/sync
''   frames suppressed by default; a >=GAP_MS gap inserts a blank line to segment bursts.
''
'' =================================================================================================


con

  _clkfreq = 200_000_000

  QUIET_IDLE = TRUE                                            ' suppress idle keepalive/sync frames
  GAP_MS     = 500                                            ' idle gap (ms) that inserts a burst divider
  LINE_MAX   = 512


obj

  mitm : "tmd700_mitm"                                         ' the MITM bridge (UARTs, forwarder, frame ring)
  strs : "jm_strings"                                          ' string build + number formatting


var

  byte  linebuf[LINE_MAX]
  long  last_emit_ms
  long  n_frames
  long  n_idle
  long  ct_alive


pub main() | p

  mitm.start(mitm.MODE_PASS)                                   ' transparent inline: forward + decode

  debug("TM-D700 MITM monitor (object build)  (57600 8N1)")
  debug("  idle keepalives suppressed; [ms] receive timestamps; blank line = idle gap")

  last_emit_ms := 0
  ct_alive := getct()

  repeat
    p := mitm.next_frame()
    if p
      show_frame(p)
    elseif (getct() - ct_alive) >= (clkfreq * 5)              ' periodic liveness when quiet
      ct_alive := getct()
      debug("  -- alive: frames=", udec_(n_frames), "  idle=", udec_(n_idle), "  overflow=", udec_(mitm.overflows()))


pri show_frame(^mitm.rxframe pf) | i, c, gap, BYTE tmp[16]

  '' Print one complete frame as "[ms] HEAD/BODY: ..." in a single DEBUG call.

  if QUIET_IDLE and (pf.attr & (mitm.ATTR_KEEPALIVE | mitm.ATTR_CR))
    n_idle++
    return

  n_frames++

  gap := pf.ms - last_emit_ms
  if (last_emit_ms <> 0) and (gap >= GAP_MS)
    debug(" ")
  last_emit_ms := pf.ms

  byte[@linebuf] := 0

  strs.append_char(@linebuf, "[")
  strs.rjdec(pf.ms, 8, " ", @tmp)
  strs.append_str(@linebuf, @tmp)
  strs.append_str(@linebuf, string("] "))

  if pf.dir == mitm.DIR_BODY
    strs.append_str(@linebuf, string("BODY: "))
  else
    strs.append_str(@linebuf, string("HEAD: "))

  repeat i from 0 to pf.len - 1
    c := pf.payload[i]
    if (c >= $20) and (c <= $7E)
      strs.append_char(@linebuf, c)
    else
      strs.append_str(@linebuf, string("[0x"))
      strs.fxhex(c, 2, @tmp)
      strs.append_str(@linebuf, @tmp)
      strs.append_char(@linebuf, "]")

  debug(zstr_(@linebuf))
